# =============================================================================
# Investor Copilot API - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values you need.
# Never commit your .env file.

# --- LLM (optional for local heuristic mode) ---
# Used by the intent classifier and the Portfolio Health agent.
# If both GEMINI_API_KEY and OPENAI_API_KEY are configured, GEMINI is used by default.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Application ---
APP_ENV=development              # development | production | test

# =============================================================================
# Optional — only set what you actually use
# =============================================================================

# --- Persistence (your choice) ---
# Sessions can be persisted to Postgres, SQLite, or kept in-memory.
# Set this only if you choose Postgres / a real DB.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# --- Pre-classifier vector DB ---
# Only if you implement the optional embedding-based pre-classifier (stretch).
PGVECTOR_DATABASE_URL=

# --- Cache backend ---
# Only if you implement the optional dedupe cache (stretch) and choose Redis.
# Leave blank to use in-memory caching.
REDIS_URL=
